<style>
  :root {
    --black:#0d0d0d; --white:#f5f2ed; --green:#25d366;
    --green-dark:#128c7e; --green-light:rgba(37,211,102,.08);
    --gray:#999; --card:#141414; --border:#222; --border-light:#2a2a2a;
    --red:#e74c3c;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--black);color:var(--white);font-family:'DM Sans',sans-serif;min-height:100vh;display:flex;flex-direction:column;}

/* ── NAV ── */
nav{padding:1.25rem 2rem;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(–border);}
.logo{display:flex;align-items:center;gap:8px;text-decoration:none;color:var(–white);}
.logo-dot{width:9px;height:9px;background:var(–green);border-radius:50%;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.3)}}
.logo-text{font-family:‘Syne’,sans-serif;font-weight:800;font-size:1.3rem;}
.back-link{color:var(–gray);text-decoration:none;font-size:.88rem;transition:color .2s;}
.back-link:hover{color:var(–white);}

/* ── MAIN ── */
main{flex:1;display:flex;align-items:center;justify-content:center;padding:2rem 1.5rem;position:relative;overflow:hidden;}
main::before{content:’’;position:absolute;top:-200px;left:50%;transform:translateX(-50%);width:600px;height:600px;background:radial-gradient(circle,rgba(37,211,102,.05) 0%,transparent 65%);pointer-events:none;}

/* ── CARD ── */
.card{background:var(–card);border:1px solid var(–border);border-radius:20px;padding:2.5rem;width:100%;max-width:420px;animation:fadeUp .5s ease both;}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

.card-icon{width:48px;height:48px;background:var(–green-light);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:1.5rem;border:1px solid rgba(37,211,102,.2);}
.card h1{font-family:‘Syne’,sans-serif;font-size:1.6rem;font-weight:800;letter-spacing:-0.5px;margin-bottom:.4rem;}
.card p{font-size:.88rem;color:var(–gray);margin-bottom:2rem;}

/* ── TABS ── */
.tabs{display:flex;background:var(–black);border-radius:10px;padding:4px;margin-bottom:1.5rem;border:1px solid var(–border);}
.tab{flex:1;padding:.6rem;border:none;background:none;color:var(–gray);font-family:‘DM Sans’,sans-serif;font-size:.85rem;font-weight:500;cursor:pointer;border-radius:7px;transition:all .2s;}
.tab.active{background:var(–card);color:var(–white);border:1px solid var(–border-light);}

/* ── FORM ── */
.form-group{margin-bottom:1rem;}
.form-group label{display:block;font-size:.75rem;font-weight:600;color:var(–gray);margin-bottom:6px;letter-spacing:.3px;text-transform:uppercase;}
.form-group input{width:100%;padding:.75rem 1rem;background:var(–black);border:1.5px solid var(–border);border-radius:10px;color:var(–white);font-family:‘DM Sans’,sans-serif;font-size:.9rem;outline:none;transition:border-color .2s,box-shadow .2s;}
.form-group input:focus{border-color:var(–green);box-shadow:0 0 0 3px rgba(37,211,102,.1);}
.form-group input::placeholder{color:#444;}

.error-box{background:rgba(231,76,60,.1);border:1px solid rgba(231,76,60,.3);border-radius:8px;padding:.75rem 1rem;font-size:.82rem;color:#e74c3c;margin-bottom:1rem;display:none;}
.error-box.show{display:block;}

.btn-submit{width:100%;padding:.9rem;background:var(–green);border:none;border-radius:10px;color:#000;font-family:‘Syne’,sans-serif;font-weight:700;font-size:.95rem;cursor:pointer;transition:all .2s;margin-top:.5rem;display:flex;align-items:center;justify-content:center;gap:8px;}
.btn-submit:hover{background:#1db954;transform:translateY(-1px);box-shadow:0 6px 20px rgba(37,211,102,.25);}
.btn-submit:disabled{background:var(–border);color:var(–gray);cursor:not-allowed;transform:none;box-shadow:none;}
.btn-submit .spinner{width:16px;height:16px;border:2px solid rgba(0,0,0,.3);border-top-color:#000;border-radius:50%;animation:spin .6s linear infinite;display:none;}
.btn-submit.loading .spinner{display:block;}
.btn-submit.loading .btn-text{display:none;}
@keyframes spin{to{transform:rotate(360deg)}}

.divider{display:flex;align-items:center;gap:1rem;margin:1.25rem 0;color:var(–border-light);font-size:.78rem;color:var(–gray);}
.divider::before,.divider::after{content:’’;flex:1;height:1px;background:var(–border);}

.forgot-link{display:block;text-align:center;color:var(–gray);font-size:.82rem;text-decoration:none;margin-top:1rem;transition:color .2s;}
.forgot-link:hover{color:var(–green);}

/* ── REGISTER EXTRA ── */
.plan-select{background:var(–black);border:1.5px solid var(–border);border-radius:10px;color:var(–white);font-family:‘DM Sans’,sans-serif;font-size:.9rem;padding:.75rem 1rem;width:100%;outline:none;cursor:pointer;}
.plan-select:focus{border-color:var(–green);}
.plan-select option{background:#1a1a1a;}

/* ── TRUST ── */
.trust{display:flex;justify-content:center;gap:1.5rem;flex-wrap:wrap;margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(–border);}
.trust-item{font-size:.72rem;color:#555;display:flex;align-items:center;gap:5px;}

/* ── SUCCESS ── */
.success-state{display:none;text-align:center;padding:1rem 0;}
.success-icon{width:60px;height:60px;background:var(–green-light);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:24px;border:1px solid rgba(37,211,102,.3);}
.success-title{font-family:‘Syne’,sans-serif;font-size:1.3rem;font-weight:800;margin-bottom:.5rem;}
.success-desc{font-size:.88rem;color:var(–gray);margin-bottom:1.5rem;}

@media(max-width:480px){nav{padding:1rem;}.card{padding:1.75rem;}}
</style>

</head>
<body>

