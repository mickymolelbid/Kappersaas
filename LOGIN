<script>
const SUPABASE_URL = 'https://ftqeiuqodmwgufdxigwk.supabase.co';
const SUPABASE_KEY = 'sb_publishable_J3oKDHRYZ7jj_DlyoY-glg_HoF69-nN';

function switchTab(tab, btn) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('form-login').style.display = tab === 'login' ? 'block' : 'none';
  document.getElementById('form-register').style.display = tab === 'register' ? 'block' : 'none';
  hideError();
}

function showError(msg) {
  const box = document.getElementById('error-box');
  box.textContent = msg;
  box.classList.add('show');
}

function hideError() {
  document.getElementById('error-box').classList.remove('show');
}

function setLoading(btnId, loading) {
  const btn = document.getElementById(btnId);
  btn.classList.toggle('loading', loading);
  btn.disabled = loading;
}

async function login() {
  hideError();
  const email = document.getElementById('login-email').value.trim();
  const ww = document.getElementById('login-ww').value;

  if (!email || !ww) { showError('Vul alle velden in.'); return; }

  setLoading('btn-login', true);

  try {
    const res = await fetch(`${SUPABASE_URL}/auth/v1/token?grant_type=password`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'apikey': SUPABASE_KEY,
      },
      body: JSON.stringify({ email, password: ww })
    });

    const data = await res.json();

    if (data.access_token) {
      localStorage.setItem('sb-token', data.access_token);
      localStorage.setItem('sb-user', JSON.stringify(data.user));
      window.location.href = '/dashboard';
    } else {
      showError('Verkeerd e-mailadres of wachtwoord.');
    }
  } catch (err) {
    showError('Verbindingsfout. Probeer opnieuw.');
  } finally {
    setLoading('btn-login', false);
  }
}

async function register() {
  hideError();
  const salon = document.getElementById('reg-salon').value.trim();
  const email = document.getElementById('reg-email').value.trim();
  const ww = document.getElementById('reg-ww').value;
  const plan = document.getElementById('reg-plan').value;

  if (!salon || !email || !ww) { showError('Vul alle velden in.'); return; }
  if (ww.length < 8) { showError('Wachtwoord moet min. 8 tekens zijn.'); return; }

  setLoading('btn-register', true);

  try {
    const res = await fetch(`${SUPABASE_URL}/auth/v1/signup`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'apikey': SUPABASE_KEY,
      },
      body: JSON.stringify({
        email,
        password: ww,
        data: { salon_naam: salon, plan }
      })
    });

    const data = await res.json();

    if (data.id || data.user) {
      document.getElementById('form-register').style.display = 'none';
      document.getElementById('success-state').style.display = 'block';
    } else {
      showError(data.msg || 'Registratie mislukt. Probeer opnieuw.');
    }
  } catch (err) {
    showError('Verbindingsfout. Probeer opnieuw.');
  } finally {
    setLoading('btn-register', false);
  }
}

// Enter key support
document.addEventListener('keydown', e => {
  if (e.key === 'Enter') {
    if (document.getElementById('form-login').style.display !== 'none') login();
    else register();
  }
});

// Check if already logged in
const token = localStorage.getItem('sb-token');
if (token) window.location.href = '/dashboard';
</script>

